<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_list"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/finanzapp_widget_bg"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Próximos pagos"
            android:textColor="#E8EDEA"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/w_list_period"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#8A9590"
            android:textSize="11sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/r0"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView android:id="@+id/r0_text" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:maxLines="1" android:ellipsize="end" android:text=""
            android:textColor="#E8EDEA" android:textSize="13sp" />
        <TextView android:id="@+id/r0_amount" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:layout_marginStart="8dp"
            android:text="" android:textColor="#E8EDEA" android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/r1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView android:id="@+id/r1_text" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:maxLines="1" android:ellipsize="end" android:text=""
            android:textColor="#E8EDEA" android:textSize="13sp" />
        <TextView android:id="@+id/r1_amount" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:layout_marginStart="8dp"
            android:text="" android:textColor="#E8EDEA" android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/r2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView android:id="@+id/r2_text" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:maxLines="1" android:ellipsize="end" android:text=""
            android:textColor="#E8EDEA" android:textSize="13sp" />
        <TextView android:id="@+id/r2_amount" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:layout_marginStart="8dp"
            android:text="" android:textColor="#E8EDEA" android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/r3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView android:id="@+id/r3_text" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:maxLines="1" android:ellipsize="end" android:text=""
            android:textColor="#E8EDEA" android:textSize="13sp" />
        <TextView android:id="@+id/r3_amount" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:layout_marginStart="8dp"
            android:text="" android:textColor="#E8EDEA" android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/w_list_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Todo al día este mes"
        android:textColor="#8A9590"
        android:textSize="13sp"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#1F2A26" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Total pendiente"
            android:textColor="#8A9590" android:textSize="11sp" />
        <TextView android:id="@+id/w_list_total" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="—"
            android:textColor="#2DD891" android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
