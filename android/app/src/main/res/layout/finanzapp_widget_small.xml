<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_small"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/finanzapp_widget_bg"
    android:padding="14dp">

    <TextView
        android:id="@+id/w_small_when"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ESTE MES"
        android:textColor="#8A9590"
        android:textSize="11sp"
        android:fontFamily="monospace" />

    <TextView
        android:id="@+id/w_small_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="—"
        android:textColor="#E8EDEA"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/w_small_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="—"
        android:textColor="#2DD891"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Finanzapp · tocá para pagar"
        android:textColor="#5C6661"
        android:textSize="10sp" />
</LinearLayout>
