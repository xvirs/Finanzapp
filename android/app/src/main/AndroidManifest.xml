<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">
    <!-- Local notifications (recordatorios pre-vencimiento) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- La app programa notificaciones con alarmas INEXACTAS
         (AndroidScheduleMode.inexactAllowWhileIdle en notification_service.dart),
         así que NO necesita permisos de alarma exacta. flutter_local_notifications
         los inyecta por defecto en su manifest; los removemos del manifest final
         para cumplir la política de Play (USE_EXACT_ALARM solo se permite en apps
         cuya función principal es despertador o calendario). -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" tools:node="remove"/>
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" tools:node="remove"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <application
        android:label="Finanzapp"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:resizeableActivity="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Supabase magic-link / OAuth callback (deep link) -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="finanzapp" android:host="login-callback"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- Impeller habilitado (renderer Vulkan, default de Flutter en
             Android). Anteriormente lo teníamos en `false` por un crash en
             el detail pane del Mes en Fold inner, pero la causa raíz era un
             `IntrinsicHeight` envolviendo cards con AnimatedCurrency dentro
             que generaba un loop de re-layout. Ya corregido. Si reaparecen
             crashes nativos en algún device específico, volver a `false`. -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="true" />

        <!-- Widget de pantalla de inicio (próximo vencimiento / pulso del mes). -->
        <receiver
            android:name=".FinanzappWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/finanzapp_widget_info" />
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Apps de pago / wallets / bancos (Argentina). Sin estas
             entradas, Android 11+ oculta las apps con scheme custom
             de nuestro launchUrl(). Agregar acá cualquier scheme
             nuevo que se vaya soportando. -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="mercadopago"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="modo"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="uala"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="naranjax"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="brubank"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="bgalicia"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="santandermobile"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="bbvanetcash"/>
        </intent>
        <!-- HTTPS (App Links): permite que launchUrl resuelva URLs
             https a la app correspondiente cuando esté instalada
             (Mercado Pago, Modo, etc. soportan App Links). -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
    </queries>
</manifest>
