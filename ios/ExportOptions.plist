<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Store distribution: el IPA se firma con el cert "Apple
         Distribution" + un provisioning profile App Store. Xcode los
         genera automáticamente con auto-signing. -->
    <key>method</key>
    <string>app-store</string>

    <!-- Team ID del Apple Developer account. -->
    <key>teamID</key>
    <string>SJVXS34P6P</string>

    <!-- Bitcode: deprecated por Apple desde Xcode 14, false. -->
    <key>uploadBitcode</key>
    <false/>

    <!-- Symbols: incluir dSYMs en el IPA. Útiles para Crashlytics
         deobfuscation y para que App Store Connect muestre stack
         traces legibles. -->
    <key>uploadSymbols</key>
    <true/>

    <!-- Manual signing: sin device físico, no se puede usar automatic
         porque Xcode intenta crear un profile de Development que
         requiere al menos un device. Usamos el profile App Store
         creado manualmente en developer.apple.com. -->
    <key>signingStyle</key>
    <string>manual</string>
    <key>signingCertificate</key>
    <string>Apple Distribution</string>
    <key>provisioningProfiles</key>
    <dict>
        <key>app.finanzapp.client</key>
        <string>Finanzapp App Store</string>
        <!-- Extensión WidgetKit. Necesita su propio App ID + profile App
             Store en el portal (con la capability App Groups). El profile
             del app (arriba) también debe regenerarse con App Groups. -->
        <key>app.finanzapp.client.FinanzappWidget</key>
        <string>Finanzapp Widget App Store</string>
    </dict>

    <!-- Compresión: deja que Apple Connect optimice el IPA. -->
    <key>destination</key>
    <string>export</string>
</dict>
</plist>
